{
  "manifest_version": 3,
  "name": "AI Prompt Vault",
  "version": "0.1.0",
  "description": "Save, organize, search, tag and insert AI prompts into ChatGPT, Claude, Gemini, Perplexity and more. Offline-first.",
  "minimum_chrome_version": "116",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "AI Prompt Vault (Alt+P)",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "permissions": [
    "storage",
    "contextMenus",
    "scripting",
    "activeTab",
    "sidePanel",
    "clipboardWrite"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://www.perplexity.ai/*",
        "https://perplexity.ai/*",
        "https://copilot.microsoft.com/*",
        "https://chat.deepseek.com/*",
        "https://grok.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": { "default": "Alt+P" },
      "description": "Open the Prompt Vault popup"
    },
    "open-side-panel": {
      "suggested_key": { "default": "Alt+Shift+P" },
      "description": "Open the Prompt Vault side panel"
    }
  }
}
